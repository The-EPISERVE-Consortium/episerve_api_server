# lakeFS — credentials are loaded automatically from K8s secrets by run_local.sh
LAKEFS_URL=https://lake-episerve.zib.de
LAKEFS_RAW_REPO=data-raw
LAKEFS_PROCESSED_REPO=data-processed
LAKEFS_MODEL_RUNS_REPO=model-runs
LAKEFS_BRANCH=main

# CKAN — API token loaded automatically from K8s secrets by run_local.sh
CKAN_URL=

# Prefect — no API key needed for self-hosted Prefect within the cluster
PREFECT_API_URL=
PREFECT_MODEL_RUNNER_DEPLOYMENT=model-runner/model-pipeline
